FROM node:20-slim

WORKDIR /app

COPY package*.json ./
COPY packages/shared-ui/package*.json ./packages/shared-ui/
COPY packages/shared-utils/package*.json ./packages/shared-utils/
COPY apps/host-app/package*.json ./apps/host-app/
COPY apps/dashboard-app/package*.json ./apps/dashboard-app/
COPY apps/project-app/package*.json ./apps/project-app/
COPY apps/task-app/package*.json ./apps/task-app/

RUN npm install

COPY . .

EXPOSE 3000 3001 3002 3003

# Vite Module Federation requires remoteEntry.js files, which are generated only at build time.
# We build only the remote applications (dashboard, project, task) to generate these assets.
# The host-app is run in development mode (next dev) directly so it compiles dynamically.
CMD ["sh", "-c", "npm run build -w apps/dashboard-app -w apps/project-app -w apps/task-app && npx concurrently \"npm run dev -w apps/host-app\" \"npm run preview -w apps/dashboard-app\" \"npm run preview -w apps/project-app\" \"npm run preview -w apps/task-app\""]
